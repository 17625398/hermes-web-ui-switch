# ============================
# hermes-web-ui 环境变量配置
# ============================
# 复制此文件为 .env 并修改相应值，重启 dev server 后生效

# ============================
# Koa 后端 + Vite 代理共享配置（dev 模式）
# ============================
# 此变量同时被以下组件读取：
#   1) Vite 开发服务器 — 将 /api、/v1、/health 等 HTTP 请求代理到此地址
#   2) Koa 后端 — 启动时自动加载 .env，将其代理中间件的上游地址设为该值
#   3) Koa 后端的 ChatRunSocket — 通过代理中间件将 Socket.IO 消息转发到此地址
#
# 本地开发时：http://127.0.0.1:8648（本机 Koa 后端，Koa 再通过 GatewayManager 转给本地 Agent）
# 分离部署时：http://<远程 IP>:8642（远程 Hermes Agent，Koa 代理中间件直接转发）
#
# 注意：Socket.IO 客户端（浏览器）在 dev 模式直连 Koa 后端 (http://127.0.0.1:8648)，
#       不再经过 Vite 代理。Koa 收到 Socket.IO 消息后，通过其内置代理中间件将
#       /v1/responses 等请求转发到此地址。因此分离部署时需确保此地址指向远程 Agent。
VITE_HERMES_GATEWAY_URL=http://127.0.0.1:8648

# 远程 Agent 的 API Key（与远程 agent config.yaml 中的 API_SERVER_KEY 一致）
# 分离部署时 Koa 后端的代理中间件会用此值作为 Authorization header。
# 本地开发时无需设置。
# VITE_HERMES_GATEWAY_API_KEY=your-api-key-here

# ============================
# Web UI 认证配置
# ============================
# 认证 Token（登录页面验证用，与后端 AUTH_TOKEN 一致）
# AUTH_TOKEN=your-token-here

# ============================
# 其他可选配置
# ============================
# Web UI 数据目录
# HERMES_WEB_UI_HOME=/path/to/hermes-web-ui-data
# Web UI 服务端口
# PORT=8648
# 上传目录
# UPLOAD_DIR=/path/to/uploads
# Gateway 主机（本地部署时）
# GATEWAY_HOST=127.0.0.1
# 关闭 Web UI 时是否停止 gateway（0=不停止，1=停止）
# HERMES_WEB_UI_STOP_GATEWAYS_ON_SHUTDOWN=1

# ============================
# 连接设置页面（运行时配置）
# ============================
# 在 http://localhost:5173/#/hermes/settings -> 连接 页面中：
# - 本地模式：连接本机网关，无需额外配置
# - 分离部署模式：需填写服务器地址和 API Key，保存在浏览器 localStorage 中
#   此配置独立于 VITE_HERMES_GATEWAY_URL，运行时直接请求目标服务器
